# Football Data API (https://www.football-data.org/ — free tier: ~10 req/min)
# Used by src/worldcup/live.py to fetch played 2026 World Cup results and the
# confirmed 26-man squads. Auth header: X-Auth-Token. Without it the live
# update falls back to the cached results in data/raw/footballdata_api/.
FOOTBALL_DATA_API_KEY=your_key_here

# API-Football via api-sports.io (https://dashboard.api-football.com/ — free
# tier: 100 req/day, 10 req/min). Source of the 2022-2024 international match
# history in data/raw/apifootball/. Auth header: x-apisports-key.
# Base URL: https://v3.football.api-sports.io
API_FOOTBALL_KEY=your_key_here
